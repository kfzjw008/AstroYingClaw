# AstroGuide Hardware Skill - 环境配置模板
# OpenClaw 技能配置文件
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际硬件配置修改参数
# 3. 确保 .env 文件不会被提交到 Git

# ============================================
# 串口配置
# ============================================
# 串口设备名称（留空则自动检测）
# Windows 示例: COM3, COM4, COM5...
# Linux 示例: /dev/ttyUSB0, /dev/ttyACM0...
# macOS 示例: /dev/cu.usbserial-...
ASTRO_GUIDE_SERIAL_PORT=

# ============================================
# TTS 引擎配置
# ============================================
# 文字转语音引擎
# - edge: 微软 Edge 在线 TTS（推荐，音质好，需要网络）
# - pyttsx3: 离线 TTS（无需网络，备选方案）
ASTRO_GUIDE_TTS_ENGINE=edge

# ============================================
# 调试配置
# ============================================
# 强制使用 Mock 模式（用于无硬件测试）
# 设为 "true" 启用，留空或设为其他值禁用
ASTRO_GUIDE_FORCE_MOCK=
